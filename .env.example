# Fine Flow — Variables de entorno
# Copia a .env y rellena los valores reales

# Oracle Database
ORACLE_R2DBC_URL=r2dbc:oracle:thin:@(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=localhost)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=XEPDB1)))
ORACLE_USER=fineflow_user
ORACLE_PASSWORD=your_oracle_password

# JWT — Generar con: openssl rand -base64 64
JWT_SECRET=your_base64_encoded_secret_key_must_be_at_least_512_bits

# Config Server
CONFIG_PASSWORD=your_config_server_password

# Anthropic (para el chatbot RAG)
ANTHROPIC_API_KEY=sk-ant-your-key-here
